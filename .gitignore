# Memory & Recordings
/[Mm]emoryCaptures/
/[Rr]ecordings/

# =========================
# Unity Meta Handling
# =========================
# Never ignore Asset meta data
!/[Aa]ssets/**/*.meta

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

