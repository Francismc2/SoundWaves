# IDE & Editor Files
# =========================
.vs/
.gradle/
.consulo/
ExportedObj/

# Visual Studio / Rider
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.DotSettings.user

# VS Code settings (ignore all except shared settings if needed)
/.vscode/*
!.vscode/settings.json

